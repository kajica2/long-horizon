// BeatRender Genesis — Prisma schema
// Source of truth: /workspace/beatrender-genesis-engine.md §2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for dev (file at prisma/dev.db). Swap to Postgres for prod —
  // schema is compatible, only this block changes.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Artwork {
  id            String   @id
  seed          String
  soundtrack    String   // canonical JSON: Soundtrack
  audioDNA      String   // canonical JSON: AudioDNA
  visualDNA     String?  // canonical JSON: VisualDNA (optional — image-driven genome, action 13)
  planetaryDNA  String?  // canonical JSON: PlanetaryDNA (optional — moment capture)
  birthChart    String?  // canonical JSON: BirthChart (optional — personal chart)
  birthLocation String?  // canonical JSON: BirthLocation (optional — alongside birthChart)
  shaderGraph   String   // canonical JSON: ShaderGraph
  createdAt     DateTime
  creator       String
  title         String?
  parentId      String?  // canonical JSON: remix chain (action 20)

  comments      Comment[]
  reactions     Reaction[]
  items         CollectionItem[]

  @@index([creator])
  @@index([createdAt])
  @@index([parentId])
}

model Comment {
  id         String   @id @default(cuid())
  artworkId  String
  body       String
  author     String   // user id / "anonymous" / session-id
  createdAt  DateTime @default(now())

  artwork    Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId, createdAt])
}

model Reaction {
  id         String   @id @default(cuid())
  artworkId  String
  likerId    String   // anonymous session id, or user id when auth lands
  kind       String   @default("heart") // "heart" | future kinds
  createdAt  DateTime @default(now())

  artwork    Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([artworkId, likerId, kind])
  @@index([artworkId])
}

model Collection {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String
  curator     String
  createdAt   DateTime         @default(now())

  items       CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  artworkId    String
  position     Int

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([collectionId, artworkId])
  @@index([collectionId, position])
}